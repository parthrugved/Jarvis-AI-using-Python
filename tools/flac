#!/usr/bin/env python3
import io
import sys


def main() -> int:
    # SpeechRecognition calls: flac --stdout --totally-silent --best -
    # We ignore flags and read WAV bytes from stdin, then emit FLAC bytes to stdout.
    wav_bytes = sys.stdin.buffer.read()
    if not wav_bytes:
        return 1

    try:
        import soundfile as sf
    except Exception as e:
        sys.stderr.write(
            "Missing dependency 'soundfile'. Install it with: pip install soundfile\n"
        )
        sys.stderr.write(f"{e}\n")
        return 2

    try:
        audio, samplerate = sf.read(io.BytesIO(wav_bytes), dtype="int16")
        out = io.BytesIO()
        sf.write(out, audio, samplerate, format="FLAC", subtype="PCM_16")
        sys.stdout.buffer.write(out.getvalue())
        return 0
    except Exception as e:
        sys.stderr.write(f"FLAC conversion failed: {e}\n")
        return 3


if __name__ == "__main__":
    raise SystemExit(main())

